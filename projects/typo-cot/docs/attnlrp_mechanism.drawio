          <mxGeometry x="370" y="905" width="420" height="60" as="geometry" />
        </mxCell>

        <!-- ============================================ -->
        <!-- Right side: Summary / How top-k is determined -->
        <!-- ============================================ -->
        <mxCell id="topk_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#fff8e1;strokeColor=#f57f17;strokeWidth=2;arcSize=8;" vertex="1" parent="1">
