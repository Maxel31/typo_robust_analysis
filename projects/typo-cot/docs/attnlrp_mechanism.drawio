          <mxGeometry x="1230" y="250" width="35" height="35" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="&lt;b&gt;セグメント別フィルタリング&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#1565c0&quot;&gt;■ Question→CoT:&lt;/font&gt;&lt;br&gt;　質問文のoffset_mappingで文字位置を照合し&lt;br&gt;　質問文範囲外（Few-Shot, CoT, 回答）を0に設定&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#2e7d32&quot;&gt;■ CoT→Answer:&lt;/font&gt;&lt;br&gt;　[:prompt_token_count] = 0（プロンプト除外）&lt;br&gt;　[answer_token_start:] = 0（回答部分除外）&lt;br&gt;　CoT範囲のスコアのみ残る" style="rounded=1;whiteSpace=wrap;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1280" y="240" width="480" height="170" as="geometry" />
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="step3_num" value="3" style="ellipse;whiteSpace=wrap;fillColor=#f57f17;strokeColor=#e65100;fontSize=16;fontStyle=1;fontColor=#fff;" vertex="1" parent="1">
          <mxGeometry x="1230" y="435" width="35" height="35" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="&lt;b&gt;上位k件トークン抽出 (get_top_k_tokens)&lt;/b&gt;&lt;br&gt;&lt;br&gt;フィルタ後のスコアを |score| の降順でソートし&lt;br&gt;上位k件のサブワードトークンを抽出&lt;br&gt;&lt;br&gt;各トークンの情報:&lt;br&gt;　- word: トークン文字列&lt;br&gt;　- score: relevanceスコア&lt;br&gt;　- position: トークンインデックス" style="rounded=1;whiteSpace=wrap;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1280" y="425" width="480" height="145" as="geometry" />
        </mxCell>

        <!-- Step 4: Analysis usage -->
        <mxCell id="step4_num" value="4" style="ellipse;whiteSpace=wrap;fillColor=#f57f17;strokeColor=#e65100;fontSize=16;fontStyle=1;fontColor=#fff;" vertex="1" parent="1">
          <mxGeometry x="1230" y="600" width="35" height="35" as="geometry" />
