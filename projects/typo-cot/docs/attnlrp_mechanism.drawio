        <!-- Step 1 -->
        <mxCell id="step1_num" value="1" style="ellipse;whiteSpace=wrap;fillColor=#f57f17;strokeColor=#e65100;fontSize=16;fontStyle=1;fontColor=#fff;" vertex="1" parent="1">
          <mxGeometry x="1230" y="140" width="35" height="35" as="geometry" />
        </mxCell>
        <mxCell id="step1" value="&lt;b&gt;LRP逆伝播&lt;/b&gt;&lt;br&gt;ターゲットトークンの出力ロジットから&lt;br&gt;Transformerの全層を逆方向に伝播し、&lt;br&gt;各入力トークンへの寄与度（relevance）を計算&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;※ bfloat16で計算（勾配オーバーフロー防止）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff9c4;strokeColor=#f57f17;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1280" y="135" width="480" height="90" as="geometry" />
